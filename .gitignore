# ─── Rust ──────────────────────────────────────────────────────────
/target
# Cargo.lock IS committed — workspace contains binary crates, so the
# lockfile pins reproducible builds for releases and CI.
Cargo.lock.bak
*.log

# ─── Python / testkit ──────────────────────────────────────────────
**/.venv/
**/__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Per-run outputs from testkit (generated WAVs etc.)
tools/testkit/outputs/

# iconlab: generated ICO/previews + auto-downloaded SIL OFL fonts.
# The final airtalk.ico + tray_icon.rgba live under airtalk/assets/
# (checked in); fonts re-download on first run, no need to vendor.
tools/iconlab/out/
tools/iconlab/fonts/

# soundlab: audition WAVs — the chosen style's parameters get baked
# into airtalk/src/feedback.rs at port time, the WAVs themselves
# aren't source.
tools/soundlab/out/

# ─── IDE / editor ──────────────────────────────────────────────────
/.idea
/.vscode
*.swp
*.swo
*~

# ─── OS cruft ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Secrets / local env ───────────────────────────────────────────
.env
.env.local
*.key
*.pem

# ─── Claude Code workspace state ───────────────────────────────────
.claude/
